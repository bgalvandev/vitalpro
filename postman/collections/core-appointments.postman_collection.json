{
  "info": {
    "name": "VitalPro Core Appointments Smoke",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Smoke checks for the Core appointments API contract."
  },
  "item": [
    {
      "name": "Get appointment by id - 200",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/appointments/{{appointmentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "appointments",
            "{{appointmentId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('response follows appointment contract', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('id');",
              "  pm.expect(body).to.have.property('status');",
              "  pm.expect(['scheduled', 'completed', 'cancelled']).to.include(body.status);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get appointment by id - 404",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/appointments/{{missingAppointmentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "appointments",
            "{{missingAppointmentId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('response follows error contract', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.code).to.eql('not_found');",
              "  pm.expect(body.message).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get appointment without auth - 401",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/appointments/{{appointmentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "appointments",
            "{{appointmentId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
