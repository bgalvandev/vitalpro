# Production environment template (documentation only).
#
# Production runs the built production image. Real values are injected at deploy
# time from the protected GitHub Environment secrets (see
# .github/workflows/deploy-production.yml), NOT from a committed file. This
# template documents the variables the production Core API container expects.
# MUST NOT contain real secrets.

# --- Core API runtime ---
# Container listens on 3000 (mapped externally by the deploy workflow).
PORT=3000
NODE_ENV=production
# Service-to-service auth secret (min 16 chars). Injected from a protected
# GitHub secret; callers must send this exact value as their Bearer token.
CORE_API_SERVICE_TOKEN=replace-with-production-service-token

# --- Database ---
# Provisioned at deploy time from the `PRODUCTION_DATABASE_URL` GitHub secret.
# Placeholder shown for shape only — never commit a real connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/vitalpro?schema=public
