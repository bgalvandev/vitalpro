{
  "name": "core-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/core-api/src",
  "projectType": "application",
  "tags": ["surface:core", "layer:interface", "type:app"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/apps/core-api"],
      "options": {
        "main": "apps/core-api/src/main.ts",
        "outputPath": "dist/apps/core-api",
        "tsConfig": "apps/core-api/tsconfig.app.json",
        "assets": []
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./node_modules/.bin/tsc -p apps/core-api/tsconfig.app.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/core-api",
        "command": "../../node_modules/.bin/vitest run --config vitest.config.ts"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/core-api",
        "command": "../../node_modules/.bin/vitest run --config vitest.integration.config.ts"
      }
    },
    "test:testcontainers": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/core-api",
        "command": "../../node_modules/.bin/vitest run --config vitest.testcontainers.config.ts"
      }
    },
    "serve:ci": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "PORT=${PORT:-3300} NODE_ENV=development node -r @swc-node/register apps/core-api/src/main.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/core-api/**/*.ts"]
      }
    }
  }
}
