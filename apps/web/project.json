{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": ["surface:core", "layer:interface", "type:app"],
  "// targets": "dev/start are inferred by @nx/next/plugin; build is pinned to webpack",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.next"],
      "cache": true,
      "options": {
        "command": "NODE_ENV=production node_modules/.bin/next build apps/web --webpack"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/web/**/*.{ts,tsx}"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./node_modules/.bin/tsc -p apps/web/tsconfig.typecheck.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/web",
        "command": "../../node_modules/.bin/vitest run --config vitest.config.ts"
      }
    }
  }
}
