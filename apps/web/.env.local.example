# Web app (Next.js) local environment template.
# Next.js loads env from THIS app directory, not the repo root.
# Copy to `apps/web/.env` (gitignored): cp apps/web/.env.local.example apps/web/.env
# This template is committed and MUST NOT contain secrets.

# --- Core API connection (server-side) ---
# Base URL the web uses to read appointments from the Core API.
CORE_API_URL=http://localhost:3000
# Bearer token sent to the Core API. Not prefixed NEXT_PUBLIC_, so it stays
# server-only and never reaches the browser bundle. Locally the API accepts any
# well-formed token; in deployed environments this must match the Core API's
# expected service token.
CORE_API_TOKEN=local-dev-core-api-token
