{
  "name": "@vitalpro/workspace",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "nx": "nx",
    "lint": "pnpm nx run-many -t lint --all",
    "typecheck": "pnpm nx run-many -t typecheck --all",
    "test": "pnpm nx run-many -t test --all",
    "build": "pnpm nx run-many -t build --all",
    "dev": "pnpm nx run-many -t dev",
    "dev:web": "pnpm nx dev web",
    "dev:api": "pnpm nx dev core-api",
    "postinstall": "pnpm run prisma:generate",
    "openapi:generate": "node scripts/contracts/generate-openapi.mjs",
    "openapi:lint": "pnpm exec redocly lint",
    "openapi:check": "pnpm run openapi:generate && git diff --exit-code contracts/openapi",
    "test:integration": "pnpm nx run-many -t test:integration",
    "test:e2e": "pnpm nx run-many -t test:e2e",
    "e2e": "pnpm nx run web-e2e:e2e",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:reset:local": "docker compose down --volumes --remove-orphans && pnpm run db:up && pnpm run db:migrate && pnpm run db:seed",
    "db:status": "docker compose ps",
    "db:logs": "docker compose logs postgres",
    "db:migrate": "pnpm run prisma:migrate:dev",
    "db:seed": "prisma db seed",
    "db:studio": "pnpm run prisma:studio",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "ai:guard": "node scripts/ai/ai-guard.mjs",
    "dead-code": "knip",
    "dupes": "jscpd apps libs tools scripts --threshold 0 --ignore \"**/*.spec.ts,**/*.spec.tsx\"",
    "check": "pnpm nx run-many -t lint,typecheck,test,build --all && pnpm run openapi:lint && pnpm run ai:guard && pnpm run dead-code && pnpm run dupes",
    "affected": "pnpm nx affected -t lint,typecheck,test,build",
    "g:clean-module": "pnpm nx g @vitalpro/tools:clean-module"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/next": "22.7.5",
    "@nx/plugin": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/vitest": "22.7.5",
    "@playwright/test": "^1.61.0",
    "@redocly/cli": "^2.34.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.40",
    "@swc/helpers": "~0.5.23",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "~4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "jscpd": "^5.0.11",
    "jsdom": "^27.4.0",
    "jsonc-eslint-parser": "^2.4.2",
    "knip": "^6.18.0",
    "nx": "22.7.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "prettier": "~3.6.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@nx/devkit": "22.7.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "next": "~16.2.9",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
