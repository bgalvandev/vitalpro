{
  "name": "@vitalpro/workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "nx": "nx",
    "lint": "pnpm nx run-many -t lint --all",
    "typecheck": "pnpm nx run-many -t typecheck --all",
    "test": "pnpm nx run-many -t test --all",
    "build": "pnpm nx run-many -t build --all",
    "openapi:lint": "pnpm exec redocly lint",
    "test:integration:core-api": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false pnpm nx run core-api:test:integration",
    "test:integration:testcontainers": "RUN_TESTCONTAINERS=true NX_DAEMON=false NX_ISOLATE_PLUGINS=false pnpm nx run core-api:test:testcontainers",
    "postman:smoke": "node scripts/testing/run-core-api-postman-smoke.mjs",
    "arazzo:verify": "node scripts/contracts/verify-core-api-arazzo-workflows.mjs",
    "pact:verify": "node scripts/contracts/verify-core-api-pacts.mjs",
    "workflow:artifacts:check": "node scripts/contracts/verify-workflow-artifacts.mjs",
    "api:advanced:check": "pnpm run test:integration:core-api && pnpm run postman:smoke && pnpm run arazzo:verify && pnpm run pact:verify",
    "api:advanced:check:full": "pnpm run api:advanced:check && pnpm run test:integration:testcontainers",
    "check": "pnpm nx run-many -t lint,typecheck,test,build --all && pnpm run openapi:lint && pnpm run workflow:artifacts:check",
    "check:sandbox": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false pnpm check",
    "affected": "pnpm nx affected -t lint,typecheck,test,build",
    "g:clean-module": "pnpm nx g @vitalpro/tools:clean-module",
    "typecheck:next": "pnpm --package=typescript@next dlx tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/plugin": "22.7.1",
    "@nx/vite": "22.7.1",
    "@nx/vitest": "22.7.1",
    "@pact-foundation/pact": "^16.0.1",
    "@redocly/cli": "^2.11.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testcontainers/postgresql": "^11.7.2",
    "@types/express": "^5.0.5",
    "@types/node": "25.6.2",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "8.46.3",
    "@typescript-eslint/parser": "8.46.3",
    "@vitest/coverage-v8": "~4.1.0",
    "eslint": "9.39.1",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "newman": "^6.2.1",
    "node-mocks-http": "^1.17.2",
    "nx": "22.7.1",
    "prettier": "~3.6.2",
    "testcontainers": "^11.7.2",
    "tslib": "^2.3.0",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.0.7"
  },
  "dependencies": {
    "@nx/devkit": "22.7.1",
    "express": "^5.1.0",
    "express-openapi-validator": "^5.6.2",
    "pg": "^8.16.3",
    "yaml": "^2.8.1"
  }
}
