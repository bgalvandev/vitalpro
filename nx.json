{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vitest.config.ts",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/eslint.config.mjs",
      "{workspaceRoot}/tsconfig.base.json"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "cache": true
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.mjs"
      ],
      "cache": true
    },
    "typecheck": {
      "inputs": [
        "production",
        "^production"
      ],
      "cache": true
    },
    "test": {
      "inputs": [
        "default",
        "^production"
      ],
      "cache": true
    },
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "@nx/vitest:test": {
      "cache": true,
      "inputs": [
        "default",
        "^production"
      ]
    }
  },
  "analytics": false,
  "generators": {
    "@nx/js:library": {
      "bundler": "tsc",
      "linter": "eslint",
      "unitTestRunner": "vitest",
      "testEnvironment": "node",
      "strict": true,
      "config": "project",
      "useProjectJson": true
    },
    "@vitalpro/tools:clean-module": {
      "domain": "core",
      "directory": "libs"
    }
  }
}
