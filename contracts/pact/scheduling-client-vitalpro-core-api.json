{
  "consumer": {
    "name": "SchedulingClient"
  },
  "provider": {
    "name": "VitalProCoreApi"
  },
  "interactions": [
    {
      "description": "a request for an existing appointment",
      "providerStates": [
        {
          "name": "appointment apt-001 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/v1/appointments/apt-001",
        "headers": {
          "Authorization": "Bearer local-test-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "body": {
          "id": "apt-001",
          "status": "scheduled"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "scheduled|completed|cancelled"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "3.0.0"
    },
    "pact-js": {
      "version": "16.0.1"
    }
  }
}
