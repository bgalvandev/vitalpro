# AI / agent local config
# Portable skills live in .agents/skills (read by Codex and other agents);
# .claude/skills is a symlink so Claude Code discovers the same files.
# Share team-owned config; keep personal/machine-specific overrides local.
.agents/*
!.agents/skills/
.claude/*
!.claude/skills
!.claude/agents/
!.claude/settings.json
.claude/settings.local.json
.cursor/
.aider*
.codex/

# Nx local cache
.nx/

vitest.config.*.timestamp*