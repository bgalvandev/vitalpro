# Local development environment template.
# Copy to `.env` and adjust for your machine: `cp .env.local.example .env`
# `.env` is gitignored; this template is committed and MUST NOT contain secrets.

# --- Core API runtime ---
# Port the Core API listens on (defaults to 3000 when unset).
PORT=3000
# Node runtime mode: development | production | test.
NODE_ENV=development
# Shared secret the Core API requires as the Bearer token on /api/* (min 16
# chars). Must match the web app's CORE_API_TOKEN (apps/web/.env.local).
CORE_API_SERVICE_TOKEN=local-dev-core-api-token

# --- Database ---
# Connection string for the local PostgreSQL provisioned by docker compose.
# Start it with `pnpm db:up` (see docker-compose.yml; host port 5433).
# Integration tests (`pnpm test:integration`) also run against this database.
DATABASE_URL=postgresql://vitalpro:vitalpro@localhost:5433/vitalpro?schema=public
